# default_paths — Platform configuration for VASP Workflow GUI
#
# First-time setup:
#   make setup          (copies this file to default_paths)
#   edit default_paths  for your system
#   make run
#
# This file uses Makefile variable syntax (KEY = value).
# The Makefile includes it and exports all variables as environment variables
# that the GUI reads at startup into its CONFIG defaults.
#
# Three-layer configuration:
#   1. site.env (this file) — sets default values via the Makefile on startup.
#   2. System Setup page in the GUI — lets you change any path interactively;
#      saved to settings.json in your projects directory and auto-synced to
#      profiles/slurm.json for SLURM agent runs.
#   3. profiles/workstation.json — used when running vasp-agent.py directly
#      from the command line (without the GUI).  Leave empty strings to inherit
#      from environment variables / site.env defaults.
#
# Precedence: GUI-saved settings (settings.json) > site.env > built-in defaults.
# Lines starting with # are comments.

# ── Python interpreter ──────────────────────────────────────────────────────
# Full path recommended if conda/virtualenv is not auto-activated in your shell
PYTHON = python3

# ── VASP executables ────────────────────────────────────────────────────────
# vasp_std : collinear calculations (default)
# vasp_ncl : non-collinear / spin-orbit coupling
# vasp_gam : Gamma-point only (faster for large supercells)
VASP_STD = ~/BIN/vasp_std
VASP_NCL = ~/BIN/vasp_ncl
VASP_GAM = ~/BIN/vasp_gam

# ── LOBSTER (bonding analysis, 08_lobster step) ─────────────────────────────
# Path or name of the lobster binary.  Must be on PATH or a full path.
LOBSTER_X = lobster

# ── POTCAR library ──────────────────────────────────────────────────────────
# Directory that contains element sub-folders (e.g. Ga/, As/ …)
# Leave commented out to inherit $VASP_POTCAR_DIR from your shell (~/.bashrc).
# VASP_POTCAR_DIR = /path/to/PAW_PBE

# ── MPI launcher ────────────────────────────────────────────────────────────
# Prefix used before the VASP binary in run.sh scripts.
# Common values:
#   mpirun -np          (Open MPI, standard Linux/Mac)
#   mpiexec -n          (Intel MPI, MPICH)
#   srun -n             (SLURM clusters)
# Set MPI_NP = 1 (or leave MPI_LAUNCH empty) for serial execution.
MPI_LAUNCH = mpirun -np
MPI_NP     = 16

# ── Wannier90 executable ─────────────────────────────────────────────────────
# Use full path if wannier90.x is not on your PATH
WANNIER90_X = wannier90.x

# ── Structure visualizer (optional) ─────────────────────────────────────────
# Application used to open POSCAR/CIF files (Jmol, VESTA, OVITO, …).
# Leave empty to disable.  The GUI currently exposes this for future use;
# the SC_SNAPS tool uses it to open structures with a single click.
# Examples:
#   VISUALIZER_X = ~/bin/jmol
#   VISUALIZER_X = /Applications/VESTA.app/Contents/MacOS/VESTA
#   VISUALIZER_X = ovito
# VISUALIZER_X =
